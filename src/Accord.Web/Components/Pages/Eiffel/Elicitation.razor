@page "/eiffel"
@attribute [Authorize]
@rendermode InteractiveServer
@inject ITemplateService TemplateService
@inject IRequirementService RequirementService
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<PageTitle>Elicitation</PageTitle>

<h1 class="mb-4">Requirements Elicitation</h1>

@if (_templateSets.Count == 0)
{
    <p class="text-muted">Loading templates...</p>
}
else
{
    <div class="row g-4">
        <div class="col-lg-5">
            <div class="mb-3">
                <input class="form-control" type="search" placeholder="Search templates…"
                       @bind="_search" @bind:event="oninput" />
            </div>

            <div class="list-group mb-4" style="max-height: 40vh; overflow-y: auto;">
                @foreach (var t in FilteredTemplates)
                {
                    <button type="button"
                            class="list-group-item list-group-item-action @(t.Id == _selectedTemplate?.Id ? "active" : "")"
                            @onclick="() => SelectTemplate(t)">
                        @t.Name
                        <small class="@(t.Id == _selectedTemplate?.Id ? "text-white-50" : "text-muted") ms-1">v@t.Version</small>
                    </button>
                }
                @if (!FilteredTemplates.Any())
                {
                    <div class="list-group-item text-muted">No templates match your search.</div>
                }
            </div>

            @if (_config is not null)
            {
                <div class="mb-4">
                    <div class="btn-group flex-wrap" role="group">
                        @foreach (var (key, variant) in _config.Variants)
                        {
                            <input type="radio" class="btn-check" name="variant" id="variant-@key"
                                   checked="@(_selectedVariantKey == key)"
                                   @onchange="() => SelectVariant(key)" />
                            <label class="btn btn-outline-secondary" for="variant-@key">@variant.Name</label>
                        }
                    </div>
                </div>

                @if (ActiveVariant is not null)
                {
                    <div class="row g-3">
                        @foreach (var ruleKey in ActiveVariant.Rules)
                        {
                            var rule = _config.Rules[ruleKey];
                            var displayType = DisplayType.For(rule);
                            var colClass = rule.Size switch
                            {
                                "small" => "col-3",
                                "large" => "col-9",
                                "full" => "col-12",
                                _ => "col-6"
                            };
                            <div class="@colClass">
                                <label class="form-label fw-semibold">
                                    @rule.Name
                                    @if (rule.Optional)
                                    {
                                        <span class="text-muted fw-normal ms-1">(optional)</span>
                                    }
                                </label>
                                @if (displayType == "select")
                                {
                                    <select class="form-select"
                                            @onchange="e => OnFieldChange(ruleKey, e.Value?.ToString() ?? string.Empty)">
                                        <option value="">@(rule.Hint ?? "Select…")</option>
                                        @foreach (var val in rule.GetValues())
                                        {
                                            <option value="@val" selected="@(_fieldValues.GetValueOrDefault(ruleKey) == val)">@val</option>
                                        }
                                    </select>
                                }
                                else if (displayType == "textarea")
                                {
                                    <textarea class="form-control" rows="3"
                                              placeholder="@rule.Hint"
                                              @oninput="e => OnFieldChange(ruleKey, e.Value?.ToString() ?? string.Empty)">@_fieldValues.GetValueOrDefault(ruleKey)</textarea>
                                }
                                else
                                {
                                    <input type="text" class="form-control"
                                           placeholder="@rule.Hint"
                                           value="@_fieldValues.GetValueOrDefault(ruleKey)"
                                           @oninput="e => OnFieldChange(ruleKey, e.Value?.ToString() ?? string.Empty)" />
                                }
                            </div>
                        }
                    </div>
                }
            }
        </div>

        <div class="col-lg-7">
            <div class="card h-100">
                <div class="card-body d-flex flex-column gap-3">
                    <div>
                        <h6 class="text-muted text-uppercase small mb-2">Requirement Preview</h6>
                        <pre class="bg-light border rounded p-3 mb-0" style="white-space: pre-wrap; min-height: 6rem;">@if (string.IsNullOrWhiteSpace(_parsingResult?.Requirement))
                        {
                            <span class="text-muted fst-italic">Select a template and fill in the fields to see the generated requirement.</span>
                        }
                        else
                        {
                            @_parsingResult.Requirement
                        }</pre>
                    </div>

                    @if (_parsingResult is not null)
                    {
                        @if (_parsingResult.Errors.Count > 0)
                        {
                            <ul class="list-unstyled mb-0">
                                @foreach (var log in _parsingResult.Errors)
                                {
                                    <li class="text-danger small">@log.Message</li>
                                }
                            </ul>
                        }
                        @if (_parsingResult.Warnings.Count > 0)
                        {
                            <ul class="list-unstyled mb-0">
                                @foreach (var log in _parsingResult.Warnings)
                                {
                                    <li class="text-warning small">@log.Message</li>
                                }
                            </ul>
                        }
                        @if (_parsingResult.Notices.Count > 0)
                        {
                            <ul class="list-unstyled mb-0">
                                @foreach (var log in _parsingResult.Notices)
                                {
                                    <li class="text-muted small">@log.Message</li>
                                }
                            </ul>
                        }
                    }

                    <div class="mt-auto d-flex align-items-center gap-3">
                        <button class="btn btn-primary"
                                disabled="@(!CanSave)"
                                @onclick="SaveRequirementAsync">
                            Save Requirement
                        </button>
                        @if (_saved)
                        {
                            <span class="text-success small">Requirement saved.</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private readonly CancellationTokenSource _cts = new();

    private List<TemplateSet> _templateSets = [];
    private string _search = "";
    private Template? _selectedTemplate;
    private TemplateConfig? _config;
    private string? _selectedVariantKey;
    private Dictionary<string, string> _fieldValues = new();
    private ParsingResult? _parsingResult;
    private bool _saved;

    private IEnumerable<Template> FilteredTemplates =>
        _templateSets
            .SelectMany(s => s.Templates)
            .Where(t => string.IsNullOrWhiteSpace(_search) ||
                        t.Name.Contains(_search, StringComparison.OrdinalIgnoreCase));

    private VariantDefinition? ActiveVariant =>
        _config is not null && _selectedVariantKey is not null &&
        _config.Variants.TryGetValue(_selectedVariantKey, out var v) ? v : null;

    private bool CanSave =>
        _parsingResult is not null &&
        !string.IsNullOrWhiteSpace(_parsingResult.Requirement) &&
        _parsingResult.Ok();

    protected override async Task OnInitializedAsync()
    {
        _templateSets = await TemplateService.GetTemplateSets();
    }

    private void SelectTemplate(Template template)
    {
        _selectedTemplate = template;
        _config = TemplateService.ParseConfig(template);
        _fieldValues = new();
        _parsingResult = null;
        _saved = false;
        _selectedVariantKey = _config.Variants.Keys.FirstOrDefault();
        if (_selectedVariantKey is not null)
            RunParser();
    }

    private void SelectVariant(string key)
    {
        _selectedVariantKey = key;
        _fieldValues = new();
        RunParser();
    }

    private void OnFieldChange(string ruleKey, string value)
    {
        _fieldValues[ruleKey] = value;
        _saved = false;
        RunParser();
    }

    private void RunParser()
    {
        if (_config is null || _selectedVariantKey is null)
            return;
        _parsingResult = ParisParser.Parse(_config, _selectedVariantKey, _fieldValues);
    }

    private async Task SaveRequirementAsync()
    {
        if (_selectedTemplate is null || _parsingResult is null || !CanSave)
            return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdString = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (!Guid.TryParse(userIdString, out var userId))
            return;

        await RequirementService.SaveAsync(userId, _selectedTemplate.Id, _parsingResult.Requirement);

        _saved = true;
        try
        {
            await Task.Delay(3000, _cts.Token);
        }
        catch (OperationCanceledException) { }
        finally
        {
            _saved = false;
            StateHasChanged();
        }
    }

    public void Dispose() => _cts.Cancel();
}
