@page "/eiffel"
@attribute [Authorize]
@rendermode InteractiveServer
@inject ITemplateService TemplateService
@inject IRequirementService RequirementService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>EIFFEL — Accord</PageTitle>

<!-- Template Picker Modal -->
<div class="modal fade" id="template-picker-modal" tabindex="-1" aria-label="Schablone wählen">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0 pb-1">
                <input id="template-search" class="form-control form-control-lg" type="search"
                       placeholder="Schablone suchen…"
                       @bind="_modalSearch" @bind:event="oninput"
                       autocomplete="off" />
            </div>
            <div class="modal-body pt-2" style="max-height: 60vh; overflow-y: auto;">
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var t in FilteredModalTemplates)
                    {
                        <button type="button"
                                class="btn btn-outline-secondary @(t.Id == _selectedTemplate?.Id ? "active" : "")"
                                @onclick="() => SelectTemplateAsync(t)">
                            @t.Name
                        </button>
                    }
                    @if (!FilteredModalTemplates.Any())
                    {
                        <p class="text-muted mb-0 small">Keine Schablonen gefunden.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Two-column layout: always rendered so history is visible from the start -->
<div class="row g-4">

    <!-- Left: Template info + form -->
    <div class="col-lg-8">

        <!-- Template header -->
        <div class="d-flex align-items-start justify-content-between mb-3 gap-3">
            <div>
                @if (_config is null)
                {
                    <p class="text-muted mb-0">Wählen Sie eine Schablone, um zu beginnen.</p>
                }
                else
                {
                    <div class="text-muted small">Aktuelle Schablone</div>
                    <div class="fw-semibold fs-5 lh-sm">@_selectedTemplate!.Name</div>
                    @if (!string.IsNullOrEmpty(_config.Description))
                    {
                        <div class="text-muted small mt-1">@_config.Description</div>
                    }
                }
            </div>
            <button type="button" class="btn btn-outline-secondary btn-sm shrink-0"
                    @onclick="OpenTemplatePicker">
                @(_config is null ? "Schablone wählen" : "Ändern") <kbd class="ms-1">Ctrl+F</kbd>
            </button>
        </div>

        @if (_config is not null && ActiveVariant is not null)
        {
            <!-- Variant picker -->
            <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
                <div class="btn-group flex-wrap" role="group" aria-label="Schablonenvariante">
                    @foreach (var (key, variant) in _config.Variants)
                    {
                        <input type="radio" class="btn-check" name="variant" id="variant-@key"
                               checked="@(_selectedVariantKey == key)"
                               @onchange="() => SelectVariantAsync(key)" />
                        <label class="btn btn-outline-secondary btn-sm" for="variant-@key">
                            @variant.Name
                        </label>
                    }
                </div>
                <span class="text-muted small">
                    <kbd>Alt</kbd>+<kbd>←</kbd> / <kbd>→</kbd>
                </span>
            </div>

            <!-- Collapsible template info -->
            @if (!string.IsNullOrEmpty(GetSchablonenaufbau()) || !string.IsNullOrEmpty(ActiveVariant.Example) || !string.IsNullOrEmpty(ActiveVariant.Description))
            {
                <div class="accordion accordion-flush border rounded mb-4" id="template-info-accordion">
                    @if (!string.IsNullOrEmpty(GetSchablonenaufbau()))
                    {
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed py-2 small" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#info-aufbau"
                                        aria-expanded="false" aria-controls="info-aufbau">
                                    Schablonenaufbau
                                </button>
                            </h2>
                            <div id="info-aufbau" class="accordion-collapse collapse">
                                <div class="accordion-body py-2 font-monospace small">@GetSchablonenaufbau()</div>
                            </div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(ActiveVariant.Example))
                    {
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed py-2 small" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#info-beispiel"
                                        aria-expanded="false" aria-controls="info-beispiel">
                                    Beispielsatz
                                </button>
                            </h2>
                            <div id="info-beispiel" class="accordion-collapse collapse">
                                <div class="accordion-body py-2 fst-italic small">@ActiveVariant.Example</div>
                            </div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(ActiveVariant.Description))
                    {
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed py-2 small" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#info-beschreibung"
                                        aria-expanded="false" aria-controls="info-beschreibung">
                                    Beschreibung
                                </button>
                            </h2>
                            <div id="info-beschreibung" class="accordion-collapse collapse">
                                <div class="accordion-body py-2 small">@ActiveVariant.Description</div>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Elicitation form -->
            <div id="eiffel-form">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <h6 class="text-muted text-uppercase small fw-semibold mb-0">Anforderung erfassen</h6>
                </div>
                <div class="row g-2 mb-3">
                    @foreach (var ruleKey in ActiveVariant.Rules)
                    {
                        var rule = _config.Rules[ruleKey];
                        var displayType = DisplayType.For(rule);
                        var colClass = rule.Size switch
                        {
                            "small" => "col-md-3",
                            "large" => "col-md-9",
                            "full" => "col-12",
                            _ => "col-md-6"
                        };
                        var inputId = $"field-{ruleKey}";

                        <div class="@colClass">
                            @if (displayType == "readonly")
                            {
                                <input type="text" id="@inputId"
                                       class="form-control form-control-sm eiffel-fixed"
                                       value="@(rule.GetValues().FirstOrDefault() ?? string.Empty)"
                                       readonly tabindex="-1" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center gap-1 mb-1">
                                    @if (!string.IsNullOrEmpty(rule.Explanation))
                                    {
                                        <span class="eiffel-info" role="button"
                                              data-bs-toggle="tooltip" data-bs-placement="top"
                                              title="@rule.Explanation">i</span>
                                    }
                                    else
                                    {
                                        <span class="eiffel-info-placeholder"></span>
                                    }
                                    <label class="form-label small mb-0" for="@inputId">
                                        @rule.Name
                                        @if (rule.Optional)
                                        {
                                            <span class="text-muted fw-normal ms-1">(optional)</span>
                                        }
                                    </label>
                                </div>

                                @if (displayType == "datalist")
                                {
                                    var listId = $"list-{ruleKey}";
                                    <input type="text" id="@inputId" list="@listId"
                                           class="form-control form-control-sm"
                                           placeholder="@rule.Hint"
                                           value="@_fieldValues.GetValueOrDefault(ruleKey)"
                                           @oninput="e => OnFieldChange(ruleKey, e.Value?.ToString() ?? string.Empty)" />
                                    <datalist id="@listId">
                                        @foreach (var val in rule.GetValues())
                                        {
                                            <option value="@val" />
                                        }
                                    </datalist>
                                }
                                else if (displayType == "textarea")
                                {
                                    <textarea id="@inputId" class="form-control form-control-sm" rows="2"
                                              placeholder="@rule.Hint"
                                              @oninput="e => OnFieldChange(ruleKey, e.Value?.ToString() ?? string.Empty)">@_fieldValues.GetValueOrDefault(ruleKey)</textarea>
                                }
                                else
                                {
                                    <input type="text" id="@inputId" class="form-control form-control-sm"
                                           placeholder="@rule.Hint"
                                           value="@_fieldValues.GetValueOrDefault(ruleKey)"
                                           @oninput="e => OnFieldChange(ruleKey, e.Value?.ToString() ?? string.Empty)" />
                                }
                            }
                        </div>
                    }
                </div>

                <!-- Parsing feedback -->
                @if (_parsingResult is not null)
                {
                    @foreach (var log in _parsingResult.Errors)
                    {
                        <div class="text-danger small mb-1"><strong>Fehler:</strong> @log.Message</div>
                    }
                    @foreach (var log in _parsingResult.Warnings)
                    {
                        <div class="text-warning small mb-1">@log.Message</div>
                    }
                    @foreach (var log in _parsingResult.Notices)
                    {
                        <div class="text-muted small mb-1">@log.Message</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_parsingResult.Requirement))
                    {
                        <div class="bg-light border rounded p-3 mb-3 font-monospace small">
                            @_parsingResult.Requirement
                        </div>
                    }
                }

                <!-- Check button -->
                <button id="check-btn" type="button"
                        class="btn btn-primary w-100 py-2"
                        disabled="@(!CanSave)"
                        @onclick="CheckRequirementAsync">
                    Anforderung prüfen <kbd class="ms-2">Alt+Enter</kbd>
                </button>

                <!-- Status message -->
                @if (_statusMessage is not null)
                {
                    <div class="alert @(_statusIsSuccess ? "alert-success" : "alert-warning") py-2 small mt-2 mb-0">
                        @_statusMessage
                    </div>
                }
            </div>
        }
    </div>

    <!-- Right: Requirement history -->
    <div class="col-lg-4">
        <h6 class="text-muted text-uppercase small fw-semibold mb-1">Zuletzt erfasste Anforderungen</h6>
        <p class="text-muted small mb-3">
            Ihre letzten @(_recentRequirements.Count > 0 ? _recentRequirements.Count.ToString() : "0")/150 erfassten Anforderungen.
            Klicken zum Kopieren.
        </p>
        @if (_recentRequirements.Count == 0)
        {
            <p class="text-muted fst-italic small">Noch keine Anforderungen erfasst.</p>
        }
        else
        {
            <div class="d-flex flex-column gap-2">
                @foreach (var req in _recentRequirements)
                {
                    <button type="button" class="btn history-item"
                            title="Klicken zum Kopieren"
                            @onclick="() => CopyToClipboardAsync(req.Content)">
                        @req.Content
                    </button>
                }
            </div>
        }
    </div>

</div>

@code {
    private readonly CancellationTokenSource _cts = new();

    private List<TemplateSet> _templateSets = [];
    private List<Requirement> _recentRequirements = [];
    private string _modalSearch = "";
    private Guid _userId;

    private Template? _selectedTemplate;
    private TemplateConfig? _config;
    private string? _selectedVariantKey;
    private Dictionary<string, string> _fieldValues = new();
    private ParsingResult? _parsingResult;
    private string? _statusMessage;
    private bool _statusIsSuccess;
    private bool _needsTooltipInit;
    private bool _needsFocusFirstInput;

    private IEnumerable<Template> FilteredModalTemplates =>
        _templateSets
            .SelectMany(s => s.Templates)
            .Where(t => string.IsNullOrWhiteSpace(_modalSearch) ||
                        t.Name.Contains(_modalSearch, StringComparison.OrdinalIgnoreCase));

    private VariantDefinition? ActiveVariant =>
        _config is not null && _selectedVariantKey is not null &&
        _config.Variants.TryGetValue(_selectedVariantKey, out var v) ? v : null;

    private bool CanSave =>
        _parsingResult is not null &&
        !string.IsNullOrWhiteSpace(_parsingResult.Requirement) &&
        _parsingResult.Ok();

    protected override async Task OnInitializedAsync()
    {
        _templateSets = await TemplateService.GetTemplateSets();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdStr = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (Guid.TryParse(userIdStr, out var id))
        {
            _userId = id;
            _recentRequirements = [.. await RequirementService.GetByUserAsync(_userId)];
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("eiffel.init");

        if (firstRender || _needsTooltipInit)
        {
            _needsTooltipInit = false;
            await JS.InvokeVoidAsync("eiffel.initTooltips");
        }

        if (_needsFocusFirstInput)
        {
            _needsFocusFirstInput = false;
            await JS.InvokeVoidAsync("eiffel.focusFirstInput");
        }
    }

    private void OpenTemplatePicker()
    {
        _modalSearch = "";
        JS.InvokeVoidAsync("eiffel.showModal", "template-picker-modal");
    }

    private async Task SelectTemplateAsync(Template template)
    {
        _selectedTemplate = template;
        _config = TemplateService.ParseConfig(template);
        _selectedVariantKey = _config.Variants.Keys.FirstOrDefault();
        _fieldValues = new();
        _parsingResult = null;
        _statusMessage = null;
        PrefillFixedValues();
        RunParser();
        _needsTooltipInit = true;
        _needsFocusFirstInput = true;
        await JS.InvokeVoidAsync("eiffel.hideModal", "template-picker-modal");
    }

    private async Task SelectVariantAsync(string key)
    {
        _selectedVariantKey = key;
        _fieldValues = new();
        _parsingResult = null;
        PrefillFixedValues();
        RunParser();
        _needsTooltipInit = true;
        _needsFocusFirstInput = true;
        await Task.CompletedTask;
    }

    private void PrefillFixedValues()
    {
        if (_config is null || ActiveVariant is null) return;
        foreach (var key in ActiveVariant.Rules)
        {
            var rule = _config.Rules[key];
            if (rule.Type == "equals")
            {
                var values = rule.GetValues();
                if (values.Length > 0)
                    _fieldValues[key] = values[0];
            }
        }
    }

    private void OnFieldChange(string ruleKey, string value)
    {
        _fieldValues[ruleKey] = value;
        _statusMessage = null;
        RunParser();
    }

    private void RunParser()
    {
        if (_config is null || _selectedVariantKey is null) return;
        _parsingResult = ParisParser.Parse(_config, _selectedVariantKey, _fieldValues);
    }

    private async Task CheckRequirementAsync()
    {
        if (!CanSave || _selectedTemplate is null || _parsingResult is null || _userId == Guid.Empty) return;

        var requirement = _parsingResult.Requirement;

        await RequirementService.SaveAsync(_userId, _selectedTemplate.Id, requirement);
        await JS.InvokeVoidAsync("eiffel.copyToClipboard", requirement);

        _recentRequirements = [.. await RequirementService.GetByUserAsync(_userId)];

        _fieldValues = new();
        PrefillFixedValues();
        _parsingResult = null;
        RunParser();

        _statusMessage = "Anforderung erfasst und in Zwischenablage kopiert.";
        _statusIsSuccess = true;
        _needsFocusFirstInput = true;

        _ = Task.Delay(3000, _cts.Token).ContinueWith(_ =>
        {
            _statusMessage = null;
            InvokeAsync(StateHasChanged);
        }, TaskContinuationOptions.NotOnCanceled);
    }

    private async Task CopyToClipboardAsync(string text) =>
        await JS.InvokeVoidAsync("eiffel.copyToClipboard", text);

    private string GetSchablonenaufbau()
    {
        if (_config is null || ActiveVariant is null) return "";
        return string.Join(" ", ActiveVariant.Rules.Select(key =>
        {
            var rule = _config.Rules[key];
            if (rule.Type == "equals") return rule.GetValues().FirstOrDefault() ?? rule.Name;
            return rule.Optional ? $"[{rule.Name}]" : $"<{rule.Name}>";
        }));
    }

    public async ValueTask DisposeAsync()
    {
        _cts.Cancel();
        try { await JS.InvokeVoidAsync("eiffel.dispose"); } catch { }
    }
}
