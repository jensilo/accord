@inject NavigationManager Navigation
@inject IStringLocalizer<NavMenu> L

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" href="/">Accord</a>
        <div class="collapse navbar-collapse">
            <div class="navbar-nav ms-auto">
                <AuthorizeView>
                    <Authorized>
                        <a class="nav-link" href="/templates">@L["Templates"]</a>
                        <a class="nav-link" href="/eiffel">EIFFEL</a>
                        <button class="btn btn-link nav-link" @onclick="Logout">@L["SignOut"]</button>
                    </Authorized>
                    <NotAuthorized>
                        <a class="nav-link" href="/auth/login">@L["SignIn"]</a>
                    </NotAuthorized>
                </AuthorizeView>
                <div class="lang-switcher">
                    <a href="@CultureUrl("de")" class="@LangClass("de")">de</a>
                    <span class="text-secondary opacity-50">·</span>
                    <a href="@CultureUrl("en")" class="@LangClass("en")">en</a>
                </div>
            </div>
        </div>
    </div>
</nav>

@code {
    void Logout() => Navigation.NavigateTo("/auth/logout", forceLoad: true);

    string CultureUrl(string culture)
    {
        var current = Navigation.Uri;
        var relative = "/" + Navigation.ToBaseRelativePath(current);
        return $"/culture/set?culture={culture}&redirectUri={Uri.EscapeDataString(relative)}";
    }

    string LangClass(string culture)
    {
        var current = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        return culture == current ? "lang-active" : "lang-link";
    }
}
