@page "/auth/login"
@inject IAuthService AuthService
@inject IMailService MailService
@inject NavigationManager Navigation

<PageTitle>Sign in — Accord</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-5">
        <h1 class="mb-4">Sign in</h1>

        @if (sent)
        {
            <div class="alert alert-success">
                <strong>Check your email.</strong> We've sent a magic link to <strong>@sentTo</strong>.
                The link expires in 15 minutes.
            </div>
        }
        else
        {
            <p class="text-muted">Enter your email address and we'll send you a sign-in link.</p>

            <form @onsubmit="Submit" @onsubmit:preventDefault>
                <div class="mb-3">
                    <label class="form-label" for="email">Email address</label>
                    <input id="email" type="email" class="form-control" @bind="email"
                           placeholder="you@example.com" required autofocus />
                </div>

                @if (error != null)
                {
                    <div class="alert alert-danger">@error</div>
                }

                <button type="submit" class="btn btn-primary w-100" disabled="@loading">
                    @(loading ? "Sending…" : "Send magic link")
                </button>
            </form>
        }
    </div>
</div>

@code {
    private string email = "";
    private string? error;
    private string? sentTo;
    private bool sent;
    private bool loading;

    async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(email)) return;

        loading = true;
        error = null;

        try
        {
            var user = await AuthService.FindOrCreateUser(email);
            var token = await AuthService.CreateMagicLinkToken(user.Id);
            var baseUri = Navigation.BaseUri.TrimEnd('/');
            var link = $"{baseUri}/auth/verify?token={Uri.EscapeDataString(token)}";
            await MailService.SendMagicLink(user.Email, link);
            sentTo = user.Email;
            sent = true;
        }
        catch
        {
            error = "Something went wrong. Please try again.";
        }
        finally
        {
            loading = false;
        }
    }
}
