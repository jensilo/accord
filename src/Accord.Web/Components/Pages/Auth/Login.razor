@page "/auth/login"
@inject IAuthService AuthService
@inject IMailService MailService
@inject NavigationManager Navigation
@inject IStringLocalizer<Login> L

<PageTitle>@L["PageTitle"]</PageTitle>

<div class="home-hero text-center py-5 px-3 rounded-3 mt-3">
    <p class="home-eyebrow">@L["Eyebrow"]</p>
    <h1 class="home-title">Accord</h1>

    <div class="row justify-content-center mt-4">
        <div class="col-md-5">
            @if (sent)
            {
                <div class="alert alert-success text-start">
                    <strong>@L["SuccessHeading"]</strong> @L["SuccessBody"] <strong>@sentTo</strong>.
                    @L["SuccessExpiry"]
                </div>
            }
            else
            {
                <form @onsubmit="Submit" @onsubmit:preventDefault>
                    <div class="mb-3 text-start">
                        <label class="form-label" for="email">@L["EmailLabel"]</label>
                        <input id="email" type="email" class="form-control" @bind="email"
                               placeholder="@L["EmailPlaceholder"]" required autofocus />
                    </div>

                    @if (error != null)
                    {
                        <div class="alert alert-danger">@error</div>
                    }

                    <button type="submit" class="btn btn-primary w-100" disabled="@loading">
                        @(loading ? L["SubmitButtonLoading"].Value : L["SubmitButton"].Value)
                    </button>
                </form>
            }
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string? error;
    private string? sentTo;
    private bool sent;
    private bool loading;

    async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(email)) return;

        loading = true;
        error = null;

        try
        {
            var user = await AuthService.FindOrCreateUser(email);
            var token = await AuthService.CreateMagicLinkToken(user.Id);
            var baseUri = Navigation.BaseUri.TrimEnd('/');
            var link = $"{baseUri}/auth/verify?token={Uri.EscapeDataString(token)}";
            await MailService.SendMagicLink(user.Email, link);
            sentTo = user.Email;
            sent = true;
        }
        catch
        {
            error = L["ErrorGeneric"];
        }
        finally
        {
            loading = false;
        }
    }
}
