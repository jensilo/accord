@inject NavigationManager Navigation

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" href="/">Accord</a>
        <div class="collapse navbar-collapse">
            <div class="navbar-nav ms-auto">
                <AuthorizeView>
                    <Authorized>
                        <a class="nav-link" href="/templates">Templates</a>
                        <a class="nav-link" href="/eiffel">EIFFEL</a>
                        <button class="btn btn-link nav-link" @onclick="Logout">Sign out</button>
                    </Authorized>
                    <NotAuthorized>
                        <a class="nav-link" href="/auth/login">Sign in</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
</nav>

@code {
    void Logout() => Navigation.NavigateTo("/auth/logout", forceLoad: true);
}
